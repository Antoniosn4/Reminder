# =============================================================
#  .gitignore — Reminder1
#  Mantém fora do repositório: dependências, builds, dados
#  sensíveis (chaves, tokens, credenciais OAuth).
# =============================================================

# ── Dependências ───────────────────────────────────────────
node_modules/
.cache/

# ── Build / Output ─────────────────────────────────────────
dist/
build/
out/

# ── Vite ───────────────────────────────────────────────────
*.local
vite.config.js.timestamp-*

# ── Logs ───────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Editor ─────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Sistema Operacional ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Ambiente Python (Backend / Server) ────────────────────
server/.venv/
.venv/
venv/
ENV/
env/
*.pyc
*.pyo
*.pyd
__pycache__/
server/__pycache__/
server/routers/__pycache__/
server/services/__pycache__/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Variáveis de Ambiente — NUNCA commitar ─────────────────
.env
.env.*
!.env.example
server/.env
server/.env.*
!server/.env.example

# ── Google Calendar OAuth — NUNCA commitar ─────────────────
server/credentials.json
server/token.json

# ── Chaves e Segredos genéricos ────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
secrets.json
secrets.yaml
secrets.yml
*_secret*
*_private*
api_keys.*

# ── Uploads e Arquivos de Mídia temporários ────────────────
server/uploads/
server/tmp/
tmp/
temp/

# ── Relatórios e Cobertura de Testes ───────────────────────
coverage/
.nyc_output/
*.lcov
